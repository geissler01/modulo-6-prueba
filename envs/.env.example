# ==============================================================================
#               UNIFIED .env.example FOR CLUSTER LOCALHOST
# ==============================================================================
# This template file serves to recreate all the individual .env files required 
# by the Apache Airflow cluster setup.
# 
# How to use:
# 1. Copy the contents of each section below.
# 2. Paste them into their respective files within the 'envs/' directory:
#    - envs/.env.global
#    - envs/.env.db
#    - envs/.env.broker
#    - envs/.env.proxy
#    - envs/.env.master
#    - envs/.env.worker
#    - envs/.env.airflow (optional documentation reference)
#
# Alternatively, you can use a bash/powershell command to split them or copy
# them manually. Make sure to replace all placeholder values (e.g. <...>) 
# with your actual credentials and keys.
# ==============================================================================

# ==============================================================================
# SECTION 1: envs/.env.global
# ==============================================================================
# Global configurations shared by both the Master nodes (Control Plane) and Workers.
# ==============================================================================

# User UID (0 for root/admin permission on local volume mounts, or 1000 for standard user)
AIRFLOW_UID=0

# Python Path configuration
PYTHONPATH=/opt/airflow/dags:/opt/airflow/tasks

# Default timezone for logs and execution
TZ=America/Bogota

# =============== DATABASE SESSION ================
# Connection URL for the Metadata database (PostgreSQL container)
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<db_name>
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<db_user>:<db_password>@postgres:5432/<db_name>

# Pool size configurations for database connections
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_SIZE=20
AIRFLOW__DATABASE__SQL_ALCHEMY_MAX_OVERFLOW=30

# =============== CORE SESSION ====================
# Directory inside container where Airflow looks for DAG files
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags

# Executor model to use (CeleryExecutor for multi-node/distributed deployments)
AIRFLOW__CORE__EXECUTOR=CeleryExecutor

# API Server URL for worker task execution state reporting
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-apiserver:8080/execution/

# Fernet key used to encrypt connection credentials in the database
# Generate one using: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=<your_generated_fernet_key_here>

# Avoid loading sample DAGs in production/staging environments
AIRFLOW__CORE__LOAD_EXAMPLES=false

# =============== CELERY SESSION ==================
# RabbitMQ Broker URL
# Format: amqp://<rabbitmq_user>:<rabbitmq_password>@<rabbitmq_host>:<rabbitmq_port>/<rabbitmq_vhost>
AIRFLOW__CELERY__BROKER_URL=amqp://<rabbitmq_user>:<rabbitmq_password>@rabbitmq:5672/airflow

# Database backend where Celery workers report their tasks status
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql+psycopg2://<db_user>:<db_password>@postgres:5432/<db_name>

# =============== OPERATORS / QUEUES SESSION ==================
# Default queue name for queuing DAG tasks
AIRFLOW__OPERATORS__DEFAULT_QUEUE=default

# =============== API SESSION ===================
# Secret key used to sign web session cookies (Generate with: openssl rand -hex 32)
AIRFLOW__API__SECRET_KEY=<your_api_secret_key_here>

# JWT secret key for Worker authentication with the API Server
AIRFLOW__API_AUTH__JWT_SECRET=<your_jwt_secret_here>

# Issuer URL for JWT tokens
AIRFLOW__API_AUTH__JWT_ISSUER=http://airflow-apiserver:8080

# =============== LOGGING SESSION ================
# Toggle remote logging to cloud storage (e.g., S3/GCS/Azure)
AIRFLOW__LOGGING__REMOTE_LOGGING=false

# =============== AUTOMATED CONNECTIONS AND VARIABLES ================
# Connection string for the Target Data Warehouse (PostgreSQL)
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
AIRFLOW_CONN_RESULTS_POSTGRES_DB=postgresql://<dw_user>:<dw_password>@<dw_host>:<dw_port>/<dw_db_name>

# Operational API Variables (e.g., Kaggle)
AIRFLOW_VAR_KAGGLE_USERNAME=<your_kaggle_username>
AIRFLOW_VAR_KAGGLE_API_TOKEN=<your_kaggle_api_token>


# ==============================================================================
# SECTION 2: envs/.env.db
# ==============================================================================
# Configurations specifically for the PostgreSQL metadata database container.
# ==============================================================================

# PostgreSQL credentials and database name
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>
TZ=America/Bogota

# External port mapping to access the database from your local machine
POSTGRES_PORT_EXTERNAL=5454

# Internal container port where PostgreSQL listens
PGPORT=5432

# Path where PostgreSQL stores its data inside the container volume
PGDATA=/var/lib/postgresql/data/pgdata


# ==============================================================================
# SECTION 3: envs/.env.broker
# ==============================================================================
# Configurations specifically for the RabbitMQ message broker container.
# ==============================================================================

# RabbitMQ admin UI/broker credentials
RABBITMQ_DEFAULT_USER=<rabbitmq_user>
RABBITMQ_DEFAULT_PASS=<rabbitmq_password>
RABBITMQ_DEFAULT_VHOST=airflow

# Erlang cookie for cluster integration/syncing multiple nodes
RABBITMQ_ERLANG_COOKIE=<your_erlang_cookie_here>

# External port mapping for AMQP protocol and Admin Web UI
RABBITMQ_PORT_AMQP_EXTERNAL=5672
RABBITMQ_PORT_UI_EXTERNAL=15672

# Internal port where RabbitMQ listens inside the container
RABBITMQ_NODE_PORT=5672


# ==============================================================================
# SECTION 4: envs/.env.proxy
# ==============================================================================
# Configurations specifically for the Nginx Proxy Manager (NPM).
# ==============================================================================

TZ=America/Bogota

# PUID and PGID to map internal container files to host permissions (standard ubuntu 1000)
PUID=1000
PGID=1000


# ==============================================================================
# SECTION 5: envs/.env.master
# ==============================================================================
# Configurations exclusively loaded by Master Services (Webserver, Scheduler, 
# DAG Processor, Flower).
# ==============================================================================

# Host ports mapped to access Airflow UI and Celery Flower dashboard
AIRFLOW_UI_PORT=8080
FLOWER_UI_PORT=5555

# Ensure new DAGs are created in a paused state to prevent accidental runs
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true

# Auth manager to use for Flask AppBuilder (FAB) authentication flow
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.FabAuthManager

# Enable scheduler health-check endpoints (/health)
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true

# Run DAG parsing in a standalone process to isolate Scheduler workload
AIRFLOW__SCHEDULER__STANDALONE_DAG_PROCESSOR=true

# Interval in seconds to scan the DAGs folder for updates (development recommendation: 5s)
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=5

# Basic Auth credentials to access the Flower monitoring panel
# Format: <username>:<password>
CELERY_FLOWER_BASIC_AUTH=<flower_username>:<flower_password>

# Enable automatic database migrations on container start
_AIRFLOW_DB_MIGRATE=true

# Automatically create an Admin Web UI user
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=<admin_password>
_AIRFLOW_WWW_USER_ROLE=Admin


# ==============================================================================
# SECTION 6: envs/.env.worker
# ==============================================================================
# Configurations loaded exclusively by the Celery Worker instances.
# ==============================================================================

# Number of Celery worker replicas/containers to run
WORKER_REPLICAS=3

# Unique name/identifier for the worker node in the cluster (leave blank to auto-generate)
CELERY_HOSTNAME=

# Queues this worker listens to (separated by commas if multiple)
QUEUES=default

# Cloud storage (AWS S3) connection details if remote logging is active in .env.global
# AIRFLOW__LOGGING__REMOTE_BASE_LOG_FOLDER=s3://<your-s3-bucket-name>/logs/
# AIRFLOW__LOGGING__REMOTE_LOG_CONN_ID=<your_ui_connection_id>
# AIRFLOW__LOGGING__ENCRYPT_S3_LOGS=false

# AWS IAM credentials for S3 bucket access (if not using IAM roles/instance profiles)
# AWS_ACCESS_KEY_ID=<your_aws_access_key>
# AWS_SECRET_ACCESS_KEY=<your_aws_secret_key>
# AWS_DEFAULT_REGION=<your_aws_region>


# ==============================================================================
# SECTION 7: envs/.env.airflow (Reference)
# ==============================================================================
# Complete reference/manual of official default parameters for Apache Airflow configuration.
# This section represents standard default parameter references.
# ==============================================================================

AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=true
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__PARALLELISM=32
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__DEFAULT_TIMEZONE=utc
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.fab_auth_manager
AIRFLOW__CORE__DONOT_PICKLE=true

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_SIZE=5
AIRFLOW__DATABASE__SQL_ALCHEMY_MAX_OVERFLOW=10
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_RECYCLE=1800

AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__LOGGING__REMOTE_LOGGING=false
AIRFLOW__LOGGING__REMOTE_BASE_LOG_FOLDER=
AIRFLOW__LOGGING__REMOTE_LOG_CONN_ID=
AIRFLOW__LOGGING__ENCRYPT_S3_LOGS=false

AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=300
AIRFLOW__SCHEDULER__PARSING_PROCESSES=2
AIRFLOW__SCHEDULER__CATCHUP_BY_DEFAULT=true
AIRFLOW__SCHEDULER__MAX_DAGRUNS_TO_CREATE_PER_LOOP=10
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=false

AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW__WEBSERVER__WORKERS=4
AIRFLOW__WEBSERVER__WORKER_TIMEOUT=120
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false

AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://postgres:postgres@localhost:5432/airflow
AIRFLOW__CELERY__WORKER_CONCURRENCY=16
AIRFLOW__CELERY__CELERYD_TIMEOUT=120
AIRFLOW__OPERATORS__DEFAULT_QUEUE=default

AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.session
