# ==============================================================================
# .env.example - Plantilla Segura para GitHub
# ==============================================================================
# Instrucciones: 
# 1. Copia este archivo y crea los 6 archivos requeridos en la carpeta 'envs/'.
# 2. Reemplaza los valores entre < > con tus contraseñas y configuraciones reales.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Archivo: envs/.env.global
# ------------------------------------------------------------------------------
# Usuario del contenedor (1000 para evitar conflictos de permisos de root en Linux)
AIRFLOW_UID=1000
# Rutas internas de Python para que Airflow encuentre los DAGs
PYTHONPATH=/opt/airflow/dags:/opt/airflow/tasks
# Zona horaria unificada para los logs
TZ=America/Bogota
# Conexión a la base de datos de metadatos de Airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<usuario_db>:<password_db>@postgres:5432/<nombre_db>
# Tamaño máximo del pool de conexiones a la base de datos
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_SIZE=20
# Conexiones extra permitidas cuando el pool está lleno
AIRFLOW__DATABASE__SQL_ALCHEMY_MAX_OVERFLOW=30
# Carpeta interna donde residen los DAGs
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
# Motor de ejecución (CeleryExecutor para clúster distribuido)
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
# URL de la API de ejecución para que los workers reporten estado
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-apiserver:8080/execution/
# Clave Fernet para encriptar secretos en la base de datos (generar con Python cryptography)
AIRFLOW__CORE__FERNET_KEY=<generar_y_pegar_tu_fernet_key_aqui>
# Desactiva los DAGs de ejemplo de Airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
# URL de conexión al broker de mensajería (RabbitMQ)
AIRFLOW__CELERY__BROKER_URL=amqp://<usuario_mq>:<password_mq>@rabbitmq:5672/<vhost_mq>
# URL donde Celery guarda el resultado de las tareas (Misma que la BD de metadatos)
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql+psycopg2://<usuario_db>:<password_db>@postgres:5432/<nombre_db>
# Cola por defecto de Celery para enviar tareas
AIRFLOW__OPERATORS__DEFAULT_QUEUE=default
# Clave secreta para las sesiones web (generar un hash seguro)
AIRFLOW__API__SECRET_KEY=<generar_y_pegar_tu_api_secret_key_aqui>
# Clave JWT para la autenticación entre Workers y el API Server
AIRFLOW__API_AUTH__JWT_SECRET=<generar_y_pegar_tu_jwt_secret_aqui>
# Emisor del token JWT
AIRFLOW__API_AUTH__JWT_ISSUER=http://airflow-apiserver:8080
# Habilitar o deshabilitar logs remotos (S3, GCS, etc)
AIRFLOW__LOGGING__REMOTE_LOGGING=false
# Conexión a la base de datos destino (Data Warehouse analítico)
AIRFLOW_CONN_RESULTS_POSTGRES_DB=postgresql://<usuario_dw>:<password_dw>@<host_dw>:<puerto_dw>/<nombre_dw>
# Nombre de usuario de la API de Kaggle
AIRFLOW_VAR_KAGGLE_USERNAME=<tu_usuario_de_kaggle>
# Token o clave de la API de Kaggle
AIRFLOW_VAR_KAGGLE_API_TOKEN=<tu_token_de_kaggle>

# ------------------------------------------------------------------------------
# 2. Archivo: envs/.env.db
# ------------------------------------------------------------------------------
# Usuario principal de la base de datos Postgres
POSTGRES_USER=<usuario_db>
# Contraseña de la base de datos
POSTGRES_PASSWORD=<password_db>
# Nombre de la base de datos de metadatos
POSTGRES_DB=<nombre_db>
# Zona horaria de la base de datos
TZ=America/Bogota
# Puerto expuesto hacia el host (tu PC local)
POSTGRES_PORT_EXTERNAL=5454
# Puerto interno donde escucha Postgres en el contenedor
PGPORT=5432
# Ruta interna del volumen donde se guardan los datos (soluciona error de Postgres 18)
PGDATA=/var/lib/postgresql/data/pgdata

# ------------------------------------------------------------------------------
# 3. Archivo: envs/.env.broker
# ------------------------------------------------------------------------------
# Usuario administrador de RabbitMQ
RABBITMQ_DEFAULT_USER=<usuario_mq>
# Contraseña de RabbitMQ
RABBITMQ_DEFAULT_PASS=<password_mq>
# Virtual Host de RabbitMQ dedicado a Airflow
RABBITMQ_DEFAULT_VHOST=<vhost_mq>
# Cookie de Erlang para la sincronización entre nodos del clúster (cadena aleatoria)
RABBITMQ_ERLANG_COOKIE=<tu_erlang_cookie_aqui>
# Puerto expuesto para el protocolo AMQP
RABBITMQ_PORT_AMQP_EXTERNAL=5672
# Puerto expuesto para la interfaz web de RabbitMQ
RABBITMQ_PORT_UI_EXTERNAL=15672
# Puerto interno donde escucha el nodo de RabbitMQ
RABBITMQ_NODE_PORT=5672

# ------------------------------------------------------------------------------
# 4. Archivo: envs/.env.proxy
# ------------------------------------------------------------------------------
# Zona horaria para Nginx Proxy Manager
TZ=America/Bogota
# User ID del sistema para permisos de volúmenes
PUID=1000
# Group ID del sistema para permisos de volúmenes
PGID=1000

# ------------------------------------------------------------------------------
# 5. Archivo: envs/.env.master
# ------------------------------------------------------------------------------
# Puerto expuesto de la interfaz de Airflow
AIRFLOW_UI_PORT=8080
# Puerto expuesto del monitor Flower
FLOWER_UI_PORT=5555
# Pausar DAGs automáticamente al crearlos (seguridad)
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
# Gestor de autenticación moderno (FAB)
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.FabAuthManager
# Habilitar el endpoint de verificación de salud (/health)
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true
# Aislar el procesador de DAGs en su propio contenedor
AIRFLOW__SCHEDULER__STANDALONE_DAG_PROCESSOR=true
# Frecuencia en segundos con la que Airflow lee la carpeta de DAGs
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=5
# Credenciales para acceder a la UI de Celery Flower
CELERY_FLOWER_BASIC_AUTH=<usuario_flower>:<password_flower>
# Ejecutar migraciones de base de datos automáticamente en el inicio
_AIRFLOW_DB_MIGRATE=true
# Crear el usuario administrador de Airflow automáticamente
_AIRFLOW_WWW_USER_CREATE=true
# Nombre del administrador de Airflow
_AIRFLOW_WWW_USER_USERNAME=<admin_airflow>
# Contraseña del administrador de Airflow
_AIRFLOW_WWW_USER_PASSWORD=<password_airflow>
# Rol otorgado al usuario administrador
_AIRFLOW_WWW_USER_ROLE=Admin

# ------------------------------------------------------------------------------
# 6. Archivo: envs/.env.worker
# ------------------------------------------------------------------------------
# Cantidad de contenedores Worker a levantar simultáneamente
WORKER_REPLICAS=3
# Nombre del host de Celery (vacío permite nombres dinámicos de Docker)
CELERY_HOSTNAME=
# Nombre de la cola o colas que escuchará este Worker
QUEUES=default
